{
  "info": {
    "name": "Mini ERP + CRM API",
    "description": "Postman collection for Mini ERP + CRM Operations Portal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@erp.local\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers?page=1&limit=10&search="
          }
        },
        {
          "name": "Create customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Customer\",\n  \"mobile\": \"9000000001\",\n  \"email\": \"test@customer.in\",\n  \"businessName\": \"Test Biz\",\n  \"customerType\": \"RETAIL\",\n  \"address\": \"Test address\",\n  \"status\": \"LEAD\"\n}"
            },
            "url": "{{baseUrl}}/customers"
          }
        },
        {
          "name": "Get customer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/customers/:id"
          }
        },
        {
          "name": "Add follow-up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Called customer\",\n  \"followUpDate\": \"2026-07-25T00:00:00.000Z\"\n}"
            },
            "url": "{{baseUrl}}/customers/:id/follow-ups"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/products?page=1&limit=10"
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wheat 50kg\",\n  \"sku\": \"WHT-50\",\n  \"category\": \"Grains\",\n  \"unitPrice\": 1600,\n  \"currentStock\": 40,\n  \"minStockAlert\": 10,\n  \"location\": \"Warehouse A\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Stock movement",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5,\n  \"type\": \"IN\",\n  \"reason\": \"Purchase receipt\"\n}"
            },
            "url": "{{baseUrl}}/products/:id/stock-movements"
          }
        }
      ]
    },
    {
      "name": "Challans",
      "item": [
        {
          "name": "List challans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans?page=1&limit=10"
          }
        },
        {
          "name": "Create draft challan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"REPLACE_CUSTOMER_ID\",\n  \"status\": \"DRAFT\",\n  \"items\": [\n    { \"productId\": \"REPLACE_PRODUCT_ID\", \"quantity\": 2 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/challans"
          }
        },
        {
          "name": "Confirm challan",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/:id/confirm"
          }
        },
        {
          "name": "Cancel challan",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/challans/:id/cancel"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/dashboard"
          }
        }
      ]
    }
  ]
}
